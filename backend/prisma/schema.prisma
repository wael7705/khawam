generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserType {
  id          String   @id @default(cuid())
  typeName    String   @unique @map("type_name") @db.VarChar(50)
  description String?  @db.Text
  nameAr      String?  @map("name_ar") @db.Text
  permissions Json?
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  @@map("user_types")
}

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique @db.VarChar(20)
  name         String    @db.VarChar(100)
  email        String?   @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  userTypeId   String    @map("user_type_id")
  isActive     Boolean   @default(true) @map("is_active")
  isEmployee   String?   @map("is_employee") @db.VarChar(20)
  employeeId   String?   @map("employee_id") @db.VarChar(50)
  department   String?   @db.VarChar(50)
  position     String?   @db.VarChar(50)
  salary       Decimal?  @db.Decimal(10, 2)
  hireDate     DateTime? @map("hire_date") @db.Date
  profileImage String?   @map("profile_image") @db.Text
  address      String?   @db.Text
  city         String?   @db.VarChar(50)
  notes        String?   @db.Text
  lastLogin    DateTime? @map("last_login")
  apiToken     String?   @map("api_token") @db.VarChar(255)
  totalOrders  Int?      @default(0) @map("total_orders")
  totalSpent   Decimal?  @default(0) @map("total_spent") @db.Decimal(12, 2)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  userType           UserType              @relation(fields: [userTypeId], references: [id])
  orders             Order[]               @relation("CustomerOrders")
  ordersCreated      Order[]               @relation("CreatorOrders")
  ordersAssigned     Order[]               @relation("AssignedOrders")
  statusChanges      OrderStatusHistory[]
  visitorTracking    VisitorTracking[]
  sessions           UserSession[]
  customerProfile    CustomerProfile?
  studioProjects     StudioProject[]
  reviews            Review[]
  likes              Like[]

  @@map("users")
}

model UserSession {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  sessionToken String    @unique @map("session_token") @db.VarChar(255)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.Text
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model CustomerProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique @map("user_id")
  companyName            String?  @map("company_name") @db.VarChar(100)
  businessType           String?  @map("business_type") @db.VarChar(50)
  taxNumber              String?  @map("tax_number") @db.VarChar(50)
  creditLimit            Decimal? @map("credit_limit") @db.Decimal(12, 2)
  paymentTerms           Int?     @map("payment_terms")
  preferredContactMethod String?  @map("preferred_contact_method") @db.VarChar(20)
  marketingConsent       Boolean? @default(false) @map("marketing_consent")
  notes                  String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model ProductCategory {
  id           String    @id @default(cuid())
  name         String?   @db.VarChar(100)
  nameAr       String?   @map("name_ar") @db.VarChar(100)
  nameEn       String?   @map("name_en") @db.VarChar(100)
  description  String?   @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  icon         String?   @db.VarChar(50)
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  products     Product[]

  @@map("product_categories")
}

model Product {
  id              String    @id @default(cuid())
  name            String?   @db.VarChar(100)
  nameAr          String?   @map("name_ar") @db.VarChar(100)
  description     String?   @db.Text
  descriptionAr   String?   @map("description_ar") @db.Text
  categoryId      String?   @map("category_id")
  price           Decimal?  @db.Decimal(12, 2)
  basePrice       Decimal?  @map("base_price") @db.Decimal(10, 2)
  imageUrl        String?   @map("image_url") @db.Text
  images          String[]  @default([])
  isActive        Boolean   @default(true) @map("is_active")
  isVisible       Boolean   @default(true) @map("is_visible")
  isFeatured      Boolean   @default(false) @map("is_featured")
  displayOrder    Int       @default(0) @map("display_order")
  sales           Int?      @default(0)
  featuredImage   String?   @map("featured_image") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  sizes      ProductSize[]
  orderItems OrderItem[]
  reviews    Review[]
  likes      Like[]

  @@map("products")
}

model ProductSize {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  sizeName        String   @map("size_name") @db.VarChar(50)
  widthCm         Decimal? @map("width_cm") @db.Decimal(8, 2)
  heightCm        Decimal? @map("height_cm") @db.Decimal(8, 2)
  widthPx         Int?     @map("width_px")
  heightPx        Int?     @map("height_px")
  priceMultiplier Decimal? @default(1.0) @map("price_multiplier") @db.Decimal(4, 2)
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_sizes")
}

model MaterialType {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  nameAr      String?  @map("name_ar") @db.VarChar(100)
  category    String?  @db.VarChar(50)
  weightGsm   Int?     @map("weight_gsm")
  thicknessMm Decimal? @map("thickness_mm") @db.Decimal(4, 2)
  color       String?  @db.VarChar(50)
  finish      String?  @db.VarChar(50)
  pricePSqm   Decimal? @map("price_per_sqm") @db.Decimal(8, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("material_types")
}

model Service {
  id           String   @id @default(cuid())
  nameAr       String   @map("name_ar") @db.VarChar(200)
  nameEn       String?  @map("name_en") @db.VarChar(200)
  descriptionAr String? @map("description_ar") @db.Text
  descriptionEn String? @map("description_en") @db.Text
  icon         String?  @db.VarChar(50)
  imageUrl     String?  @map("image_url") @db.Text
  basePrice    Decimal  @default(0) @map("base_price") @db.Decimal(10, 2)
  isActive     Boolean  @default(true) @map("is_active")
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  features     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  options   ServiceOption[]
  workflows ServiceWorkflow[]
  financialRules FinancialRule[]

  @@map("services")
}

enum PrintMode {
  bw
  color_normal
  color_laser
}

enum SizeCode {
  A1
  A2
  A3
  A4
  A5
  A6
  BOOKLET_A5
  BOOKLET_B5
  BOOKLET_A4
}

model FinancialRule {
  id           String    @id @default(cuid())
  serviceId    String    @map("service_id")
  name         String    @db.VarChar(200)
  nameEn       String?   @map("name_en") @db.VarChar(200)
  unitType     String    @map("unit_type") @db.VarChar(50)
  priority     Int       @default(0)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  service      Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  dimensions   FinancialRuleDimension[]

  @@index([serviceId, isActive])
  @@map("financial_rules")
}

model FinancialRuleDimension {
  id           String    @id @default(cuid())
  financialRuleId String @map("financial_rule_id")
  printMode    PrintMode @map("print_mode")
  sizeCode     SizeCode  @map("size_code")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  financialRule FinancialRule @relation(fields: [financialRuleId], references: [id], onDelete: Cascade)
  ranges       FinancialRuleRange[]

  @@unique([financialRuleId, printMode, sizeCode])
  @@index([financialRuleId, isActive])
  @@map("financial_rule_dimensions")
}

model FinancialRuleRange {
  id              String    @id @default(cuid())
  dimensionId      String    @map("dimension_id")
  minValue         Decimal   @map("min_value") @db.Decimal(12, 4)
  maxValue         Decimal?  @map("max_value") @db.Decimal(12, 4)
  unitPrice        Decimal   @map("unit_price") @db.Decimal(12, 4)
  displayOrder     Int       @default(0) @map("display_order")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  dimension FinancialRuleDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId, displayOrder])
  @@map("financial_rule_ranges")
}

model ServiceOption {
  id           String   @id @default(cuid())
  serviceId    String   @map("service_id")
  optionType   String?  @map("option_type") @db.VarChar(50)
  optionNameAr String?  @map("option_name_ar") @db.VarChar(100)
  optionNameEn String?  @map("option_name_en") @db.VarChar(100)
  priceModifier Decimal? @default(0) @map("price_modifier") @db.Decimal(10, 2)
  isPercentage Boolean  @default(false) @map("is_percentage")
  isDefault    Boolean  @default(false) @map("is_default")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_options")
}

model Order {
  id                 String    @id @default(cuid())
  orderNumber        String    @unique @map("order_number") @db.VarChar(20)
  customerId         String?   @map("customer_id")
  customerName       String?   @map("customer_name") @db.VarChar(100)
  customerPhone      String?   @map("customer_phone") @db.VarChar(20)
  customerWhatsapp   String?   @map("customer_whatsapp") @db.VarChar(20)
  shopName           String?   @map("shop_name") @db.VarChar(200)
  status             String    @default("pending") @db.VarChar(20)
  priority           String?   @db.VarChar(10)
  totalAmount        Decimal   @map("total_amount") @db.Decimal(12, 2)
  discountAmount     Decimal?  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount          Decimal?  @default(0) @map("tax_amount") @db.Decimal(10, 2)
  finalAmount        Decimal   @map("final_amount") @db.Decimal(12, 2)
  paidAmount         Decimal?  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount    Decimal?  @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  paymentMethod      String?   @default("sham_cash") @map("payment_method") @db.VarChar(50)
  paymentStatus      String?   @default("pending") @map("payment_status") @db.VarChar(20)
  isPaid             Boolean   @default(false) @map("is_paid")
  deliveryType       String?   @default("self") @map("delivery_type") @db.VarChar(20)
  deliveryAddress    String?   @map("delivery_address") @db.Text
  deliveryLatitude   Decimal?  @map("delivery_latitude") @db.Decimal(10, 8)
  deliveryLongitude  Decimal?  @map("delivery_longitude") @db.Decimal(11, 8)
  deliveryDate       DateTime? @map("delivery_date") @db.Date
  completedAt        DateTime? @map("completed_at")
  notes              String?   @db.Text
  staffNotes         String?   @map("staff_notes") @db.Text
  rating             Int?
  ratingComment      String?   @map("rating_comment") @db.Text
  createdById        String?   @map("created_by")
  assignedToId       String?   @map("assigned_to")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  customer      User?              @relation("CustomerOrders", fields: [customerId], references: [id])
  createdBy     User?              @relation("CreatorOrders", fields: [createdById], references: [id])
  assignedTo    User?              @relation("AssignedOrders", fields: [assignedToId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      Payment[]

  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  productId       String?  @map("product_id")
  productName     String?  @map("product_name") @db.VarChar(100)
  quantity        Int      @default(1)
  unitPrice       Decimal? @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal? @map("total_price") @db.Decimal(12, 2)
  sizeId          String?  @map("size_id")
  materialId      String?  @map("material_id")
  specifications  Json?
  designFiles     Json?    @map("design_files")
  productionNotes String?  @map("production_notes") @db.Text
  status          String   @default("pending") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  status    String   @db.VarChar(20)
  changedBy String?  @map("changed_by")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [changedBy], references: [id])

  @@map("order_status_history")
}

model Payment {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("SYP") @db.VarChar(3)
  paymentMethod   String?   @map("payment_method") @db.VarChar(50)
  paymentType     String?   @map("payment_type") @db.VarChar(20)
  transactionId   String?   @map("transaction_id") @db.VarChar(100)
  referenceNumber String?   @map("reference_number") @db.VarChar(100)
  status          String    @default("pending") @db.VarChar(20)
  paymentDate     DateTime? @map("payment_date")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model PaymentSettings {
  id            String    @id @default(cuid())
  paymentMethod String    @default("sham_cash") @map("payment_method") @db.VarChar(50)
  accountName   String?   @map("account_name") @db.VarChar(200)
  accountNumber String?   @map("account_number") @db.VarChar(100)
  phoneNumber   String?   @map("phone_number") @db.VarChar(20)
  apiKey        String?   @map("api_key") @db.VarChar(255)
  apiSecret     String?   @map("api_secret") @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@map("payment_settings")
}

model PortfolioWork {
  id           String    @id @default(cuid())
  title        String    @db.VarChar(200)
  titleAr      String?   @map("title_ar") @db.VarChar(200)
  description  String?   @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  imageUrl     String    @map("image_url") @db.Text
  images       String[]  @default([])
  category     String?   @db.VarChar(100)
  categoryAr   String?   @map("category_ar") @db.VarChar(100)
  isFeatured   Boolean   @default(false) @map("is_featured")
  isVisible    Boolean   @default(true) @map("is_visible")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  reviews Review[]
  likes   Like[]

  @@map("portfolio_works")
}

model HeroSlide {
  id           String    @id @default(cuid())
  imageUrl     String    @map("image_url") @db.Text
  isLogo       Boolean   @default(false) @map("is_logo")
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  @@map("hero_slides")
}

model PricingRule {
  id              String    @id @default(cuid())
  nameAr          String    @map("name_ar") @db.VarChar(200)
  nameEn          String?   @map("name_en") @db.VarChar(200)
  descriptionAr   String?   @map("description_ar") @db.Text
  descriptionEn   String?   @map("description_en") @db.Text
  calculationType String    @map("calculation_type") @db.VarChar(20)
  basePrice       Decimal   @map("base_price") @db.Decimal(10, 4)
  priceMultipliers Json?    @map("price_multipliers")
  specifications  Json?
  unit            String?   @db.VarChar(50)
  isActive        Boolean   @default(true) @map("is_active")
  displayOrder    Int       @default(0) @map("display_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  @@map("pricing_rules")
}

model PricingCategory {
  id           String    @id @default(cuid())
  nameAr       String    @map("name_ar") @db.VarChar(200)
  nameEn       String?   @map("name_en") @db.VarChar(200)
  descriptionAr String?  @map("description_ar") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  icon         String?   @db.VarChar(50)
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  configs PricingConfig[]

  @@map("pricing_categories")
}

model PricingConfig {
  id           String    @id @default(cuid())
  categoryId   String    @map("category_id")
  paperSize    String    @map("paper_size") @db.VarChar(10)
  paperType    String?   @map("paper_type") @db.VarChar(50)
  printType    String    @map("print_type") @db.VarChar(20)
  qualityType  String?   @map("quality_type") @db.VarChar(20)
  pricePerPage Decimal   @map("price_per_page") @db.Decimal(10, 4)
  unit         String?   @default("صفحة") @db.VarChar(50)
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  category PricingCategory @relation(fields: [categoryId], references: [id])

  @@map("pricing_configs")
}

model ServiceWorkflow {
  id               String    @id @default(cuid())
  serviceId        String    @map("service_id")
  stepNumber       Int       @map("step_number")
  stepNameAr       String    @map("step_name_ar") @db.VarChar(200)
  stepNameEn       String?   @map("step_name_en") @db.VarChar(200)
  stepDescriptionAr String?  @map("step_description_ar") @db.Text
  stepDescriptionEn String?  @map("step_description_en") @db.Text
  stepType         String    @map("step_type") @db.VarChar(50)
  stepConfig       Json?     @map("step_config")
  displayOrder     Int       @default(0) @map("display_order")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id])

  @@map("service_workflows")
}

model VisitorTracking {
  id          String    @id @default(cuid())
  sessionId   String    @map("session_id") @db.VarChar(255)
  userId      String?   @map("user_id")
  pagePath    String    @map("page_path") @db.VarChar(500)
  referrer    String?   @db.Text
  userAgent   String?   @map("user_agent") @db.Text
  deviceType  String?   @map("device_type") @db.VarChar(50)
  browser     String?   @db.VarChar(100)
  os          String?   @db.VarChar(100)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  country     String?   @db.VarChar(100)
  city        String?   @db.VarChar(100)
  timeOnPage  Int       @default(0) @map("time_on_page")
  exitPage    Boolean   @default(false) @map("exit_page")
  entryPage   Boolean   @default(false) @map("entry_page")
  visitCount  Int       @default(1) @map("visit_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id])
  pageViews PageView[]

  @@map("visitor_tracking")
}

model PageView {
  id          String   @id @default(cuid())
  visitorId   String?  @map("visitor_id")
  sessionId   String   @map("session_id") @db.VarChar(255)
  pagePath    String   @map("page_path") @db.VarChar(500)
  timeSpent   Int      @default(0) @map("time_spent")
  scrollDepth Int      @default(0) @map("scroll_depth")
  actions     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  visitor VisitorTracking? @relation(fields: [visitorId], references: [id])

  @@map("page_views")
}

model StudioProject {
  id               String    @id @default(cuid())
  projectName      String?   @map("project_name") @db.VarChar(100)
  userId           String?   @map("user_id")
  originalImageUrl String?   @map("original_image_url") @db.Text
  processedImageUrl String?  @map("processed_image_url") @db.Text
  projectType      String?   @map("project_type") @db.VarChar(50)
  settings         Json?
  status           String?   @default("pending") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])
  logs ImageProcessingLog[]

  @@map("studio_projects")
}

model ImageProcessingLog {
  id               String   @id @default(cuid())
  projectId        String?  @map("project_id")
  toolUsed         String?  @map("tool_used") @db.VarChar(50)
  inputImageUrl    String?  @map("input_image_url") @db.Text
  outputImageUrl   String?  @map("output_image_url") @db.Text
  processingTimeMs Int?     @map("processing_time_ms")
  settings         Json?
  success          Boolean  @default(true)
  errorMessage     String?  @map("error_message") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  project StudioProject? @relation(fields: [projectId], references: [id])

  @@map("image_processing_logs")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String?  @map("product_id")
  workId    String?  @map("work_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
  work    PortfolioWork? @relation(fields: [workId], references: [id])

  @@map("reviews")
}

model Like {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String?  @map("product_id")
  workId    String?  @map("work_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
  work    PortfolioWork? @relation(fields: [workId], references: [id])

  @@unique([userId, productId])
  @@unique([userId, workId])
  @@map("likes")
}

model SystemSetting {
  id           String    @id @default(cuid())
  settingKey   String    @unique @map("setting_key") @db.VarChar(100)
  settingValue String?   @map("setting_value") @db.Text
  settingType  String?   @map("setting_type") @db.VarChar(20)
  description  String?   @db.Text
  isPublic     Boolean   @default(false) @map("is_public")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UploadedFile {
  id           String   @id @default(cuid())
  originalName String   @map("original_name") @db.VarChar(255)
  filename     String   @unique @db.VarChar(255)
  filePath     String?  @map("file_path") @db.Text
  fileUrl      String?  @map("file_url") @db.Text
  fileSize     BigInt?  @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("uploaded_files")
}
