DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khawam
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khawam
PGBOUNCER_ENABLED=false
DB_CONNECTION_LIMIT=10
QUEUE_POOL_MAX=3
SECRET_KEY=your-secret-key-change-in-production
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# مساعد خوام — Gemini (إنتاج) ثم Ollama qwen2.5:7b (بديل محلي)
ASSISTANT_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
REMOVE_BG_API_KEY=
# مجلد الملفات المرفوعة (اختياري). على Railway استخدم حجم ثابت، مثال: /data/uploads
UPLOAD_DIR=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
