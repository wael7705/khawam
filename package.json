{
  "name": "khawam",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter backend dev",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter backend build",
    "start": "pnpm --filter backend start",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:push": "pnpm --filter backend db:push",
    "db:pull": "pnpm --filter backend db:pull",
    "lint": "pnpm --filter backend lint",
    "test": "pnpm -r run test",
    "test:unit": "pnpm --filter backend test && pnpm --filter @khawam/frontend test",
    "test:e2e": "playwright test",
    "test:load": "k6 run load-tests/load.js"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "concurrently": "^9.1.0"
  }
}
